# Copy to production.env (never commit). Used when building release installers and Stripe setup.
#
# Stripe: run python account_api/dev/setup_stripe_prices.py to create tier prices.
# Payment links (legacy payment-first flow) optional until fully migrated.

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
JWT_SECRET=

# Legacy payment links (optional)
STRIPE_PAYMENT_LINK_MONTHLY=https://buy.stripe.com/test_...
STRIPE_PAYMENT_LINK_ANNUAL=https://buy.stripe.com/test_...

# Checkout Sessions API — Local vs Cloud × monthly/annual (from setup_stripe_prices.py)
STRIPE_PRICE_LOCAL_MONTHLY=price_...
STRIPE_PRICE_LOCAL_ANNUAL=price_...
STRIPE_PRICE_CLOUD_MONTHLY=price_...
STRIPE_PRICE_CLOUD_ANNUAL=price_...

# Display prices synced to marketing_site/js/account/config.js
PLAN_LOCAL_MONTHLY_DISPLAY=$9.99/mo
PLAN_LOCAL_ANNUAL_DISPLAY=$99/yr
PLAN_CLOUD_MONTHLY_DISPLAY=$14.99/mo
PLAN_CLOUD_ANNUAL_DISPLAY=$149/yr
