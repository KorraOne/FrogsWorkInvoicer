# Copy to production.env (never commit). Used when building release installers.
#
# Stripe Dashboard → Payment links → create monthly + annual links for your products.
# Use test-mode links (https://buy.stripe.com/test_…) until you go live.

STRIPE_PAYMENT_LINK_MONTHLY=https://buy.stripe.com/test_...
STRIPE_PAYMENT_LINK_ANNUAL=https://buy.stripe.com/test_...

# Optional — only needed when running scripts/configure-payment-links.ps1 -Production
STRIPE_SECRET_KEY=sk_test_...
