# Billing server configuration (copy to .env and edit)
# Loaded automatically by config.py — shell env vars override these values.

# Server (local dev — production uses /etc/frogswork/billing.env on Pi)
HOST=127.0.0.1
PORT=8080
BASE_URL=http://127.0.0.1:8080
# Production: BASE_URL=https://api.frogswork.com

# Database (default: billing.db in this folder)
# DATABASE_URL=

# API auth
JWT_SECRET=dev-secret-change-me-in-production-32chars
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=30

# Admin UI (/admin)
ADMIN_PASSWORD=dev-admin
FLASK_SECRET_KEY=dev-flask-secret-change-me-in-production
ADMIN_SESSION_HOURS=8

# Platform invoice PDFs
# PLATFORM_INVOICE_DIR=

# KorraOne letterhead (platform fee invoices)
KORRAONE_NAME=KorraOne
# KORRAONE_ABN=
# KORRAONE_ADDRESS=
# KORRAONE_BSB=
# KORRAONE_ACC=
# KORRAONE_PAYID=
KORRAONE_PAYMENT_TERMS=14 days

# Desktop app updates (optional — served at GET /releases/latest)
# CLIENT_RELEASE_VERSION=1.0.0
# CLIENT_RELEASE_URL=https://downloads.frogswork.com/FrogsWork-1.0.0-win64.zip
# CLIENT_RELEASE_SHA256=
# CLIENT_RELEASE_NOTES=Bug fixes and improvements.

# Email platform invoices (required for automatic send)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=billing@korraone.com
# SMTP_USE_TLS=1
