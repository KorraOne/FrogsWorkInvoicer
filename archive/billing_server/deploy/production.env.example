# Production environment template for Raspberry Pi
# Copy to /etc/frogswork/billing.env (root:root 600) — never commit real secrets.

HOST=127.0.0.1
PORT=8008
BASE_URL=https://api.frogswork.com

# SQLite path on Pi (adjust user/home if needed)
DATABASE_URL=/home/frogswork/frogswork/billing_server/billing.db
PLATFORM_INVOICE_DIR=/home/frogswork/frogswork/billing_server/platform_invoices

# Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32
FLASK_SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
ADMIN_PASSWORD=REPLACE_WITH_STRONG_OPERATOR_PASSWORD
ADMIN_SESSION_HOURS=8

JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=30

# KorraOne letterhead (required before sending real platform invoices)
KORRAONE_NAME=KorraOne
KORRAONE_ABN=
KORRAONE_ADDRESS=
KORRAONE_BSB=
KORRAONE_ACC=
KORRAONE_PAYID=
KORRAONE_PAYMENT_TERMS=14 days

# Desktop app updates — use the UPDATE ZIP (not setup.exe)
CLIENT_RELEASE_VERSION=
CLIENT_RELEASE_URL=https://downloads.frogswork.com/FrogsWork-1.1.0-win64.zip
CLIENT_RELEASE_SHA256=
CLIENT_RELEASE_NOTES=

# Email platform invoices (required for auto_billing.py email step)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=billing@frogswork.com
SMTP_USE_TLS=1
