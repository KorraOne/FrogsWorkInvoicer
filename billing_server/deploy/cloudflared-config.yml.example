# Cloudflare Tunnel — frogswork-api (api.frogswork.com → billing server)

# On Pi: create tunnel as user frogswork, then install cloudflared-frogswork.service
# Do NOT use `sudo cloudflared service install` if another tunnel (e.g. my-webapp) already runs under pi.

tunnel: frogswork-api
credentials-file: /home/frogswork/.cloudflared/<TUNNEL-UUID>.json

ingress:
  - hostname: api.frogswork.com
    service: http://127.0.0.1:8008
  - service: http_status:404
